{
  "name": "since-leoo/hyperf-plugin",
  "type": "library",
  "description": "一个简洁、易用的 Hyperf 插件管理系统，一键集成项目插件。",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "hyperf/command": "^3.1",
    "hyperf/db-connection": "^3.1",
    "hyperf/database": "^3.1",
    "symfony/process": "^6.0|^7.0",
    "hyperf/utils": "^3.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "SinceLeoo\\Plugin\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SinceLeoo\\Plugin\\Tests\\": "tests/"
    }
  },
  "extra": {
    "hyperf": {
      "config": "SinceLeoo\\Plugin\\ConfigProvider"
    }
  },
  "scripts":
  {
    "test": "phpunit",
    "cs-fix": "php-cs-fixer fix $1"
  }
}
